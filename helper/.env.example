# Helper bind settings
HELPER_HOST=127.0.0.1
HELPER_PORT=4318

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Gemini (set either GEMINI_API_KEY or GOOGLE_API_KEY)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Claude Code CLI
CLAUDE_CODE_CLI_PATH=claude
# CLAUDE_CODE_BIN=/absolute/path/to/claude
CLAUDE_CODE_MODEL=sonnet

# Codex CLI
CODEX_CLI_PATH=codex
# CODEX_BIN=/absolute/path/to/codex
CODEX_MODEL=gpt-5.4
