{
  "version": 1,
  "description": "Contract cases for the guarded input pipeline. Plain multilingual text keys should pass through while functional keys and modified shortcuts are blocked.",
  "cases": [
    {
      "name": "accept latin letter",
      "event": {
        "key": "a",
        "ctrlKey": false,
        "metaKey": false,
        "altKey": false
      },
      "accepted": "a"
    },
    {
      "name": "accept hangul letter",
      "event": {
        "key": "멍",
        "ctrlKey": false,
        "metaKey": false,
        "altKey": false
      },
      "accepted": "멍"
    },
    {
      "name": "accept unicode digit",
      "event": {
        "key": "٤",
        "ctrlKey": false,
        "metaKey": false,
        "altKey": false
      },
      "accepted": "٤"
    },
    {
      "name": "ignore functional key",
      "event": {
        "key": "Enter",
        "ctrlKey": false,
        "metaKey": false,
        "altKey": false
      },
      "accepted": ""
    },
    {
      "name": "ignore modifier combo",
      "event": {
        "key": "a",
        "ctrlKey": true,
        "metaKey": false,
        "altKey": false
      },
      "accepted": ""
    }
  ]
}
